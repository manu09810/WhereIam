{
  "expo": {
    "name": "WhereIam",
    "slug": "WhereIam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "whereiam",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location for country finder."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow WhereIam to access your location to show country details."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "EXPO_PUBLIC_RESTCOUNTRIES_API": "https://restcountries.com/v3.1/alpha",
      "EXPO_PUBLIC_OPENMETEO_API": "https://api.open-meteo.com/v1/forecast",
      "EXPO_PUBLIC_EXCHANGERATE_API": "https://api.exchangerate.host/convert",
      "EXPO_PUBLIC_EXCHANGERATE_API_KEY": "73deba80b9041807c660fcc359e6653c",
      "EXPO_PUBLIC_UNSPLASH_ACCESS_KEY": "RwiSvq_81KR6uZGGbjxKiQn7zCF5-BokzPWajnLzsiA",
      "EXPO_PUBLIC_GOOGLE_API_KEY": "AIzaSyDlpFwCSN9f5rqGN80dayH7inYyq5MmlaI",
      "EXPO_PUBLIC_GOOGLE_SEARCH_ENGINE_ID": "c66d69282c23145de"
    }
  }
}
